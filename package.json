{
	"name": "ts-autocode",
	"version": "0.1.0",
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Tyler-R-Kendrick/ts-autocode.git"
	},
	"description": "Train and safely rewrite decorated or directive-marked TypeScript functions.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./ax": {
			"types": "./dist/providers/ax.d.ts",
			"import": "./dist/providers/ax.js"
		}
	},
	"homepage": "https://github.com/Tyler-R-Kendrick/ts-autocode#readme",
	"bugs": {
		"url": "https://github.com/Tyler-R-Kendrick/ts-autocode/issues"
	},
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.test.json",
		"test": "node test/run.mjs",
		"check": "npm run typecheck && npm test && npm run build",
		"prepublishOnly": "npm run check"
	},
	"keywords": [
		"agentv",
		"code-optimization",
		"openinference",
		"codegen",
		"rewriter"
	],
	"devDependencies": {
		"@types/node": "^22.15.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@agentv/core": "^4.42.4",
		"@arizeai/openinference-semantic-conventions": "^2.5.0",
		"@ax-llm/ax": "^23.0.0",
		"@opentelemetry/api": "^1.9.1",
		"typescript": "^5.9.3"
	},
	"overrides": {
		"@agentv/core": {
			"@opentelemetry/exporter-trace-otlp-http": "^0.220.0"
		}
	}
}
