{
	"name": "ts-autocode",
	"version": "0.1.0",
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Tyler-R-Kendrick/ts-autocode.git"
	},
	"description": "Optimize marker-delimited TypeScript regions with Ax and apply candidates safely.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"homepage": "https://github.com/Tyler-R-Kendrick/ts-autocode#readme",
	"bugs": {
		"url": "https://github.com/Tyler-R-Kendrick/ts-autocode/issues"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc --noEmit -p tsconfig.test.json",
		"test": "vitest run",
		"check": "npm run typecheck && npm test && npm run build",
		"prepublishOnly": "npm run check"
	},
	"keywords": [
		"ax-llm",
		"code-optimization",
		"codegen",
		"rewriter"
	],
	"devDependencies": {
		"@types/node": "^22.15.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@ax-llm/ax": "^23.0.0",
		"@opentelemetry/api": "^1.9.1"
	}
}
